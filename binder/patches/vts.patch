 }
+
+// ------------------------------------------------------------------ //
+// CTABS: Topology Discovery & Tier Classification                     //
+// ------------------------------------------------------------------ //
+
+struct CpuTopologyInfo {
+    int cluster_id;
+    int core_id;
+};
+
+static CpuTopologyInfo g_ctabs_topology[CPU_SETSIZE];
+static int g_ctabs_nr_cpus;
+
+static inline int read_sysfs_int(const char *fmt, int cpu) {
+    char path[256];
+    snprintf(path, sizeof(path), fmt, cpu);
+    std::ifstream f(path);
+    int val = -1;
+    f >> val;
+    return val;
+}
+
+static inline void init_ctabs_topology() {
+    g_ctabs_nr_cpus = std::min((int)sysconf(_SC_NPROCESSORS_CONF), CPU_SETSIZE);
+    for (int cpu = 0; cpu < g_ctabs_nr_cpus; cpu++) {
+        g_ctabs_topology[cpu].core_id = read_sysfs_int(
+            "/sys/devices/system/cpu/cpu%d/topology/core_id", cpu);
+        g_ctabs_topology[cpu].cluster_id = read_sysfs_int(
+            "/sys/devices/system/cpu/cpu%d/topology/cluster_id", cpu);
+    }
+}
+
+enum CtabTier : uint8_t {
+    CTABS_TIER_UNKNOWN        = 0,
+    CTABS_TIER_SAME_CORE,        // same physical core (incl. same CPU)
+    CTABS_TIER_SAME_CLUSTER,     // same L2 cluster, different core
+    CTABS_TIER_CROSS_CLUSTER,    // different cluster / package
+    CTABS_TIER_COUNT
+};
+
+static const char *CTABS_TIER_NAME[] = {
+    "unknown", "same_core", "same_cluster", "cross_cluster",
+};
+
+static inline CtabTier ctabs_classify_tier(int cpu_a, int cpu_b) {
+    if (cpu_a < 0 || cpu_b < 0 || cpu_a >= g_ctabs_nr_cpus || cpu_b >= g_ctabs_nr_cpus)
+        return CTABS_TIER_UNKNOWN;
+    if (cpu_a == cpu_b)
+        return CTABS_TIER_SAME_CORE;
+    if (g_ctabs_topology[cpu_a].cluster_id >= 0 &&
+        g_ctabs_topology[cpu_b].cluster_id >= 0 &&
+        g_ctabs_topology[cpu_a].cluster_id == g_ctabs_topology[cpu_b].cluster_id)
+        return CTABS_TIER_SAME_CLUSTER;
+    return CTABS_TIER_CROSS_CLUSTER;
+}
+
+// Apply CPU affinity mask from a hex string (e.g. "0f" = CPUs 0-3).
+static inline void ctabs_set_affinity(const char *mask_str) {
+    cpu_set_t cpuset;
+    CPU_ZERO(&cpuset);
+    unsigned long mask;
+    if (mask_str[0] == '0' && (mask_str[1] == 'x' || mask_str[1] == 'X'))
+        mask = strtoul(mask_str + 2, nullptr, 16);
+    else
+        mask = strtoul(mask_str, nullptr, 16);
+    for (int cpu = 0; cpu < g_ctabs_nr_cpus && cpu < (int)sizeof(mask) * 8; cpu++)
+        if (mask & (1UL << cpu)) CPU_SET(cpu, &cpuset);
+    int ret = sched_setaffinity(0, sizeof(cpuset), &cpuset);
+    if (ret != 0) {
+        std::cerr << "ctabs: sched_setaffinity(0x" << std::hex << mask
+                  << std::dec << ") failed: " << strerror(errno) << std::endl;
+        exit(EXIT_FAILURE);
+    }
+}
+
+// Per-tier latency tracking wrapper around Results.
+struct TieredResults {
+    Results tier[CTABS_TIER_COUNT];
+    uint64_t count_by_tier[CTABS_TIER_COUNT] = {0};
+
+    void addTime(uint64_t nano, CtabTier t) {
+        if (t < CTABS_TIER_COUNT) {
+            tier[t].addTime(nano);
+            count_by_tier[t]++;
+        }
+    }
+    inline uint64_t getTransactions() const {
+        uint64_t n = 0;
+        for (int i = 0; i < CTABS_TIER_COUNT; i++) n += tier[i].getTransactions();
+        return n;
+    }
+    // Enable raw recording on all tiers
+    void setupRawData() {
+        for (int i = 0; i < CTABS_TIER_COUNT; i++) tier[i].setupRawData();
+    }
+    void flushRawData() {
+        for (int i = 0; i < CTABS_TIER_COUNT; i++) tier[i].flushRawData();
+    }
+    // Combine two TieredResults (for merging process pairs)
+    static TieredResults combine(const TieredResults& a, const TieredResults& b) {
+        TieredResults ret;
+        for (int i = 0; i < CTABS_TIER_COUNT; i++) {
+            ret.tier[i] = Results::combine(a.tier[i], b.tier[i]);
+            ret.count_by_tier[i] = a.count_by_tier[i] + b.count_by_tier[i];
+        }
+        return ret;
+    }
+    void dump() const {
+        std::cout << "{";
+        for (int i = 0; i < CTABS_TIER_COUNT; i++) {
+            if (i > 0) std::cout << ",";
+            std::cout << "\"" << CTABS_TIER_NAME[i] << "\":";
+            tier[i].dump();
+            std::cout << ",\"" << CTABS_TIER_NAME[i] << "_n\":"
+                      << count_by_tier[i];
+        }
+        std::cout << "}";
+    }
+    void dumpDistribution() const {
+        std::cout << "{";
+        for (int i = 0; i < CTABS_TIER_COUNT; i++) {
+            if (i > 0) std::cout << ",";
+            std::cout << "\"" << CTABS_TIER_NAME[i] << "\":";
+            tier[i].dumpDistribution();
+        }
+        std::cout << "}";
+    }
+};
+
 #endif
