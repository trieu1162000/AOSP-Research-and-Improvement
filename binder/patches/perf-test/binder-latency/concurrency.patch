+/* Batch: spawn N threads concurrently so the server pool has multiple
+ * waiting threads since in real scenarios, server can handle and
+ * spawn thread when receive concurrent request in multiple cores */
+#define MAX_CONCURRENCY 64
+static void batch_transactions(int target, TieredStats* stats, bool fifo) {
+  ASSERT(concurrency <= MAX_CONCURRENCY);
+  const char* label = fifo ? "fifo-caller" : "other-caller";
+  if (concurrency <= 1) {
+    /* Single transaction — use original inline path */
+    if (fifo) {
+      thread_transaction(target, stats);
+    } else {
+      thread_priv_t priv;
+      void* dummy;
+      pthread_t thread;
+      priv.target = target;
+      priv.stats = stats;
+      priv.thread_label = label;
+      ASSERT(!pthread_create(&thread, nullptr, &thread_start, &priv));
+      ASSERT(!pthread_join(thread, &dummy));
+    }
+    return;
+  }
+
+  pthread_t threads[MAX_CONCURRENCY];
+  thread_priv_t privs[MAX_CONCURRENCY];
+  pthread_attr_t attr;
+  struct sched_param param;
+
+  if (fifo) {
+    ASSERT(!pthread_attr_init(&attr));
+    ASSERT(!pthread_attr_setschedpolicy(&attr, SCHED_FIFO));
+    param.sched_priority = sched_get_priority_max(SCHED_FIFO);
+    ASSERT(!pthread_attr_setschedparam(&attr, &param));
+  }
+
+  for (int j = 0; j < concurrency; j++) {
+    privs[j].target = target;
+    privs[j].stats = stats;
+    privs[j].thread_label = label;
+    ASSERT(!pthread_create(&threads[j],
+           fifo ? &attr : nullptr, &thread_start, &privs[j]));
+  }
+
+  void* dummy;
+  for (int j = 0; j < concurrency; j++) {
+    ASSERT(!pthread_join(threads[j], &dummy));
+  }
+}
