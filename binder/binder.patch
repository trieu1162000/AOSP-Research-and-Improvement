+/**
+ * binder_select_thread_topology_ilocked() - topology-aware thread selection
+ * @proc:       target process
+ * @caller_cpu: CPU the calling thread is running on (smp_processor_id())
+ *
+ * Selects a waiting thread that shares L2 cache with the caller.
+ * Falls back to FIFO if no topology-local thread is available.
+ *
+ * Requires proc->inner_lock held.
+ */
+static struct binder_thread *
+binder_select_thread_topology_ilocked(struct binder_proc *proc, int caller_cpu)
+{
+	struct binder_thread *thread, *best = NULL;
+	const struct cpumask *caller_cluster;
+
+	/* Get L2-sharing cpumask for the caller's CPU */
+	caller_cluster = cpu_coregroup_mask(caller_cpu);
+
+	/* First pass: find a thread on same L2-sharing cluster */
+	list_for_each_entry(thread, &proc->waiting_threads, waiting_thread_node) {
+		int thread_cpu = task_cpu(thread->task);
+		if (cpumask_test_cpu(thread_cpu, caller_cluster)) {
+			best = thread;
+			break;
+		}
+	}
+
+	/* Second pass: same cluster_id (approximation for DynamIQ) */
+	if (!best) {
+		int caller_cluster_id = cpu_topology[caller_cpu].cluster_id;
+		list_for_each_entry(thread, &proc->waiting_threads, waiting_thread_node) {
+			int thread_cpu = task_cpu(thread->task);
+			if (cpu_topology[thread_cpu].cluster_id == caller_cluster_id) {
+				best = thread;
+				break;
+			}
+		}
+	}
+
+	/* Fallback: FIFO (existing behavior) */
+	if (!best)
+		best = list_first_entry_or_null(&proc->waiting_threads,
+				struct binder_thread, waiting_thread_node);
+
+	if (best)
+		list_del_init(&best->waiting_thread_node);
+
+	return best;
+}
